generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["paceflow"]
}

model PaceflowUser {
  id               String                 @id @default(uuid())
  email            String                 @unique
  weight           Float?
  vo2Max           Float?
  thresholdHr      Int?
  subscriptionTier String                 @default("free")
  aiCredits        Int                    @default(10)
  activePlan       Json?
  activePlanGoal   String?
  createdAt        DateTime               @default(now())
  trainingPlans    PaceflowTrainingPlan[]
  runSessions      PaceflowRunSession[]
  simulations      PaceflowSimulation[]

  @@schema("paceflow")
}

model PaceflowTrainingPlan {
  id            String       @id @default(uuid())
  userId        String
  goal          String       // E.g., "Distance: 10K, Target Pace: 5:30 /km"
  planData      Json
  createdAt     DateTime     @default(now())
  user          PaceflowUser @relation(fields: [userId], references: [id])

  @@schema("paceflow")
}

model PaceflowCourse {
  id                 String               @id @default(uuid())
  name               String
  gpxData            Json
  totalElevationGain Float
  heatIndexFactor    Float?
  runSessions        PaceflowRunSession[]
  simulations        PaceflowSimulation[]

  @@schema("paceflow")
}

model PaceflowRunSession {
  id               String                    @id @default(uuid())
  userId           String
  courseId         String
  date             DateTime
  totalTime        Int                       // in seconds
  avgPace          Float                     // min/km or min/mile
  isBaseline       Boolean                   @default(false)
  user             PaceflowUser              @relation(fields: [userId], references: [id])
  course           PaceflowCourse            @relation(fields: [courseId], references: [id])
  telemetrySamples PaceflowTelemetrySample[]

  @@schema("paceflow")
}

model PaceflowTelemetrySample {
  id                  String             @id @default(uuid())
  sessionId           String
  timestamp           BigInt             // ms precision
  lat                 Float
  lon                 Float
  elevation           Float
  cadence             Int?
  gct                 Int?               // Ground Contact Time (ms)
  verticalOscillation Float?
  heartRate           Int?
  runSession          PaceflowRunSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId, timestamp])
  @@schema("paceflow")
}

model PaceflowSimulation {
  id                 String         @id @default(uuid())
  userId             String
  courseId           String
  scenarioParams     Json
  probableFinishTime Int            // in seconds
  confidenceInterval Float
  user               PaceflowUser   @relation(fields: [userId], references: [id])
  course             PaceflowCourse @relation(fields: [courseId], references: [id])

  @@schema("paceflow")
}
